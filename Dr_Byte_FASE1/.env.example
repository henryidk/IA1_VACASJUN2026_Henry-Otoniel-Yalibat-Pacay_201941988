# Token del bot de Telegram (obtenido desde @BotFather)
TELEGRAM_TOKEN=tu_token_aqui

# ID del chat al que el bot enviará los diagnósticos
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Puerto en el que corre el backend Flask
FLASK_PORT=5000

# Modo debug de Flask (True en desarrollo, False en producción)
FLASK_DEBUG=True

# Ruta al archivo JSON donde se guarda el historial de diagnósticos
HISTORY_PATH=/data/historial.json


